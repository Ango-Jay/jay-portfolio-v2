---
import Footer from "../components/sections/Footer.astro";
import Header from "../components/sections/Header";
import ThemePicker from "../components/ThemePicker";
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content="Ango Jeffrey is a Senior Frontend Engineer with a passion for building scalable, user friendly and elegant web and mobile applications." />
		<title>Ango Jeffrey</title>
		<script type="application/ld+json">
			{
			  "@context": "https://schema.org",
			  "@type": "Person",
			  "name": "Ango Jeffrey",
			  "url": "https://angojay.com",
			  "jobTitle": "Senior Frontend Engineer",
			  "sameAs": [
				"https://dev.to/angojay",
				"https://github.com/Ango-Jay"
			  ]
			}
			</script>
		<script is:inline>
			(function () {
				try {
					var stored = localStorage.getItem("theme");
					if (stored === "system") {
						localStorage.removeItem("theme");
						stored = null;
					}
					var dark =
						stored === "dark"
							? true
							: stored === "light"
								? false
								: window.matchMedia("(prefers-color-scheme: dark)").matches;
					var root = document.documentElement;
					root.dataset.theme = dark ? "dark" : "light";
					root.classList.toggle("dark", dark);
				} catch (e) {
					var r = document.documentElement;
					r.dataset.theme = "light";
					r.classList.remove("dark");
				}
			})();
		</script>
	</head>
	<body class="min-h-screen bg-surface text-ink antialiased transition-colors duration-200 dark:bg-night dark:text-zinc-100">
		<ThemePicker client:load />
		<Header client:load />
		<slot />
		<Footer />
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>
